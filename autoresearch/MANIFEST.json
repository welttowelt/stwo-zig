  "gates_policy": {
    "require_rust_oracle": true,
    "request_budget": 1.05,
    "rss_budget": 1.05,
    "ci_level": 0.95,
    "theta_floor": 0.01,
    "dispersion_multiplier": 2.0,
    "targeted_class_budget": 1.02,
    "matrix_row_budget": 1.05,
    "search_health": {
