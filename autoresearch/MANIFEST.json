  "workload_registry": {
    "note": "Command templates are data so flag drift is a manifest edit, not a code change. The runner prepends the built bench binary of the owning group; {warmups}/{samples} come from gates policy.",
    "schema_note": "Registry v2 (manifest_version bumped 1 -> 2): workloads live in named groups, each carrying one exclusively owned board plus its own build_step, binary, report_schema, and enabled flag. v1's flat build_step/binary/workloads triple is exactly today's group 'native'; loaders reject the flat shape with a migration hint. Disabled groups are announced loudly by every runner entry point, never silently dropped.",
    "groups": {
      "native": {
        "enabled": true,
        "board": "core_cpu",
        "build_step": "zig build native-proof-bench-cpu -Doptimize=ReleaseFast",
        "binary": "zig-out/bin/native-proof-bench-cpu",
        "report_schema": "native_proof_v6",
        "workloads": {
          "wf_log10x8": {
            "class": "small",
            "args": "--example wide_fibonacci --log-n-rows 10 --sequence-len 8 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "trace rows"
          },
          "wf_log14x32": {
            "class": "wide",
            "args": "--example wide_fibonacci --log-n-rows 14 --sequence-len 32 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "trace rows"
          },
          "plonk_log14": {
            "class": "deep",
            "args": "--example plonk --log-n-rows 14 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "gates"
          }
        }
      },
      "riscv": {
        "enabled": false,
        "disabled_reason": "stark-v adapter pending release gate",
        "board": "riscv",
        "build_step": "zig build stwo-zig -Doptimize=ReleaseFast",
        "binary": "zig-out/bin/stwo-zig",
        "report_schema": "riscv_proof_v1",
        "workloads": {
          "riscv_fib_small": {
            "class": "small",
            "args": "bench --elf vectors/riscv_elfs/branch_fib.elf --backend cpu --protocol functional --warmups {warmups} --samples {samples}",
            "native_unit": "executed instructions"
          },
          "riscv_alu": {
            "class": "small",
            "args": "bench --elf vectors/riscv_elfs/alu_test.elf --backend cpu --protocol functional --warmups {warmups} --samples {samples}",
            "native_unit": "executed instructions"
          }
        }
      },
      "metal": {
        "enabled": true,
        "board": "core_metal",
        "build_step": "zig build native-proof-bench-metal -Doptimize=ReleaseFast",
        "binary": "zig-out/bin/native-proof-bench-metal",
        "report_schema": "native_proof_v6",
        "workloads": {
          "mwf_log10x8": {
            "class": "small",
            "args": "--example wide_fibonacci --log-n-rows 10 --sequence-len 8 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "trace rows"
          },
          "mwf_log14x32": {
            "class": "wide",
            "args": "--example wide_fibonacci --log-n-rows 14 --sequence-len 32 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "trace rows"
          },
          "mplonk_log14": {
            "class": "deep",
            "args": "--example plonk --log-n-rows 14 --warmups {warmups} --samples {samples} --protocol functional",
            "native_unit": "gates"
          }
        }
      }
    },
    "guards": {
      "note": "The full native AIR portfolio as mandatory regression guards (judge review, PR 20 era): one declared objective workload is SCORED, but every selected guard's paired upper confidence bound must stay below its regression budget. Guards use the objective group's binary; args are data.",
      "workloads": {
        "guard_wf_14x32": {
          "args": "--example wide_fibonacci --log-n-rows 14 --sequence-len 32 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "trace_rows"
        },
        "guard_wf_16x64": {
          "args": "--example wide_fibonacci --log-n-rows 16 --sequence-len 64 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "trace_rows"
        },
        "guard_xor_14": {
          "args": "--example xor --log-size 14 --log-step 2 --offset 3 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "xor_rows"
        },
        "guard_xor_16": {
          "args": "--example xor --log-size 16 --log-step 2 --offset 3 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "xor_rows"
        },
        "guard_plonk_14": {
          "args": "--example plonk --log-n-rows 14 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "plonk_rows"
        },
        "guard_plonk_16": {
          "args": "--example plonk --log-n-rows 16 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "plonk_rows"
        },
        "guard_sm_14": {
          "args": "--example state_machine --initial-x 9 --initial-y 3 --log-n-rows 14 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "state_transitions"
        },
        "guard_sm_16": {
          "args": "--example state_machine --initial-x 9 --initial-y 3 --log-n-rows 16 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "state_transitions"
        },
        "guard_blake_10x10": {
          "args": "--example blake --log-n-rows 10 --n-rounds 10 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "blake_round_instances"
        },
        "guard_blake_12x16": {
          "args": "--example blake --log-n-rows 12 --n-rounds 16 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "blake_round_instances"
        },
        "guard_poseidon_10": {
          "args": "--example poseidon --log-n-instances 10 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "poseidon_instances"
        },
        "guard_poseidon_13": {
          "args": "--example poseidon --log-n-instances 13 --warmups {warmups} --samples {samples} --protocol functional",
          "native_unit": "poseidon_instances"
        }
      },
      "policy": {
        "warmups": 5,
        "samples_per_round": 2,
        "min_rounds": 3,
        "max_rounds": 8,
        "budget_upper": 1.05,
        "inconclusive_extra_rounds": 4,
        "note": "pass = paired upper CI bound <= budget_upper; an inconclusive guard (CI straddling the budget after min rounds) samples inconclusive_extra_rounds more, then fails closed"
      },
      "impact_map": {
        "note": "Editable-path prefixes to the guard sets a diff must exercise; generic prover/PCS/FFT/accumulation code touches every native AIR. Unmatched editable paths select every guard (fail closed).",
        "rules": [
          {
            "prefixes": [
              "src/backends/metal/"
            ],
            "board": "core_metal",
            "guards": "all"
          },
          {
            "prefixes": [
              "src/prover/",
              "src/core/fri/",
              "src/core/pcs/",
              "src/core/fields/",
              "src/backends/cpu_scalar/"
            ],
            "guards": "all"
          },
          {
            "prefixes": [
              "src/core/crypto/"
            ],
            "guards": [
              "guard_blake_10x10",
              "guard_blake_12x16",
              "guard_poseidon_10",
              "guard_poseidon_13",
              "guard_wf_14x32",
              "guard_plonk_14"
            ]
          },
          {
            "prefixes": [
              "src/backends/metal/"
            ],
            "guards": [],
            "board": "core_cpu"
          }
        ]
      }
    },
    "holdout_generator": {
      "note": "Judged runs draw one extra hold-out per class by jittering log_n_rows/sequence_len within class bounds; seed is recorded in the ledger row. Results publish as pass/fail only.",
      "small": {
        "log_n_rows": [
          9,
