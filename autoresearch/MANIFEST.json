        ],
        "sequence_len": null
      }
    }
  },
  "gates_policy": {
    "require_rust_oracle": true,
    "request_budget": 1.05,
    "rss_budget": 1.05,
    "ci_level": 0.95,
    "theta_floor": 0.01,
    "dispersion_multiplier": 2.0,
    "targeted_class_budget": 1.02,
    "matrix_row_budget": 1.05,
    "warmups": 10,
    "samples_per_round": 3,
    "min_rounds": 7,
    "max_rounds": 15,
    "wall_clock_cap_seconds": {
      "small": 240,
      "wide": 600,
      "deep": 600
    },
    "neutral_band_note": "Promotion requires the declared-objective CI entirely below 1 - theta, where theta = max(theta_floor, dispersion_multiplier x per-class A/A dispersion recorded in the ledger epoch)."
  },
  "qualification_policy": {
    "schema_version": 1,
    "max_active_per_user": 1,
    "required_checks": [
      "allowed_diff",
      "locked_tree",
      "source_modes",
      "harness_tests",
      "release_build",
      "public_benchmark"
    ],
    "source_commit_must_descend_from_frontier": true,
    "source_modes": [
      "100644"
    ],
    "max_changed_paths": 100,
    "max_patch_bytes": 5242880,
    "require_github_artifact_attestation": true,
    "central_reverification_required": true,
    "note": "Fork CI is a cost-shifting qualification signal, never the trust root. Intake recomputes tree evidence and the central judge rebuilds and benchmarks hidden holdouts before promotion."
  },
  "scopes": {
    "s1": "kernel/function microbench (counters primary; wall time secondary)",
    "s2": "stage subtree via stage profiles (diagnostic only)",
    "s3": "complete proof transaction; acceptance floor for every submission",
    "s4": "process lifecycle: cold vs warm, sessions, pools, caches",
