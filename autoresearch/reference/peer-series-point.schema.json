{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/teddyjfpender/stwo-zig/autoresearch/reference/peer-series-point.schema.json",
  "title": "Peer-relative wide-Fibonacci series point v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "series_id",
    "measured_at_utc",
    "audit_point",
    "peer_source",
    "host",
    "toolchains",
    "measurement_contract",
    "executables",
    "proof_equivalence_receipt",
    "sizes"
  ],
  "properties": {
    "schema": {"const": "peer-relative-wide-fibonacci-series-point-v1"},
    "series_id": {"const": "clementwalter-pr6-wide-fibonacci-v1"},
    "measured_at_utc": {"type": "string", "format": "date-time"},
    "audit_point": {
      "type": "object",
      "required": ["stwo_zig_commit", "cadence"],
      "properties": {
        "stwo_zig_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "cadence": {"type": "string"}
      }
    },
    "peer_source": {
      "type": "object",
      "required": ["repository", "pull_request", "commit"],
      "properties": {
        "repository": {"const": "https://github.com/ClementWalter/stwo"},
        "pull_request": {"const": 6},
        "commit": {"const": "07ea1ccca13351028da94e66babf79e7ce91437f"}
      }
    },
    "host": {"type": "object"},
    "toolchains": {"type": "object"},
    "measurement_contract": {
      "type": "object",
      "required": ["rounds", "interleaving", "primary_metric", "log_n_rows", "sequence_len_columns", "peer_protocol", "zig_protocol", "large_resource_profile"],
      "properties": {
        "rounds": {"type": "integer", "minimum": 1},
        "warmups_per_lane_invocation": {"type": "integer", "minimum": 0},
        "interleaving": {"type": "string"},
        "primary_metric": {"const": "verified_request_ms"},
        "workload": {"const": "wide_fibonacci"},
        "log_n_rows": {"const": [14, 16, 18, 20]},
        "sequence_len_columns": {"const": 100},
        "zig_protocol": {"const": "functional"},
        "peer_protocol": {
          "type": "object",
          "required": ["channel", "pcs_config", "parameters"],
          "properties": {
            "channel": {"const": "Blake2sM31Channel/Blake2sM31MerkleChannel"},
            "pcs_config": {"const": "PcsConfig::default()"},
            "parameters": {"type": "string"}
          }
        },
        "large_resource_profile": {"type": "object"},
        "timing_semantics": {"type": "string"}
      }
    },
    "executables": {
      "type": "object",
      "required": ["peer_cpu", "peer_metal", "zig_cpu", "zig_metal"],
      "properties": {
        "peer_cpu": {"$ref": "#/$defs/executable"},
        "peer_metal": {"$ref": "#/$defs/executable"},
        "zig_cpu": {"$ref": "#/$defs/executable"},
        "zig_metal": {"$ref": "#/$defs/executable"}
      }
    },
    "proof_equivalence_receipt": {"type": "object"},
    "sizes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/size"}
    }
  },
  "$defs": {
    "executable": {
      "type": "object",
      "required": ["path", "sha256", "build_command"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "build_command": {"type": "array", "items": {"type": "string"}}
      }
    },
    "size": {
      "type": "object",
      "required": ["log_n_rows", "rows", "n_columns", "medians", "ratios", "proof_equivalence", "samples"],
      "properties": {
        "log_n_rows": {"enum": [14, 16, 18, 20]},
        "rows": {"type": "integer"},
        "n_columns": {"const": 100},
        "medians": {"type": "object"},
        "ratios": {"type": "object"},
        "proof_equivalence": {"type": "object"},
        "samples": {"type": "array", "minItems": 4}
      }
    }
  }
}
