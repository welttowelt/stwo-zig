{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/teddyjfpender/stwo-zig/autoresearch/reference/pr6-wide-series-point.schema.json",
  "title": "PR6 width-100 CPU/Metal series point v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "series_id",
    "status",
    "measured_at_utc",
    "audit_point",
    "peer_source",
    "host",
    "toolchains",
    "measurement_contract",
    "executables",
    "coverage",
    "sizes"
  ],
  "properties": {
    "schema": {"const": "peer-relative-wide-fibonacci-series-point-v2"},
    "series_id": {"const": "clementwalter-pr6-wide-fibonacci-v2"},
    "status": {"const": "diagnostic_until_full_pr6_matrix_and_sync_telemetry_exist"},
    "measured_at_utc": {"type": "string", "format": "date-time"},
    "audit_point": {
      "type": "object",
      "required": ["stwo_zig_commit", "source_tree_sha256", "shader_tree_sha256", "cadence"],
      "properties": {
        "stwo_zig_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "source_tree_sha256": {"$ref": "#/$defs/sha256"},
        "shader_tree_sha256": {"$ref": "#/$defs/sha256"},
        "cadence": {"type": "string"}
      }
    },
    "peer_source": {
      "type": "object",
      "required": ["repository", "pull_request", "commit"],
      "properties": {
        "repository": {"const": "https://github.com/ClementWalter/stwo"},
        "pull_request": {"const": 6},
        "commit": {"const": "07ea1ccca13351028da94e66babf79e7ce91437f"}
      }
    },
    "host": {"type": "object"},
    "toolchains": {"type": "object"},
    "measurement_contract": {
      "type": "object",
      "required": [
        "abba_rounds",
        "verified_warmups",
        "samples_per_abba_position",
        "interleaving",
        "timing_boundaries",
        "gate",
        "workload",
        "log_n_rows",
        "sequence_len_columns",
        "cold_process_includes_source_jit",
        "prove_ms_is_diagnostic_only",
        "no_concurrent_benchmarks"
      ],
      "properties": {
        "abba_rounds": {"type": "integer", "minimum": 7},
        "verified_warmups": {"const": 10},
        "samples_per_abba_position": {"const": 1},
        "interleaving": {"type": "string"},
        "timing_boundaries": {"const": ["verified_request", "cold_process"]},
        "gate": {"type": "object"},
        "workload": {"const": "exact PR6 WideFibonacciEval<100>"},
        "log_n_rows": {"const": [14, 16, 18, 20, 22]},
        "sequence_len_columns": {"const": 100},
        "cold_process_includes_source_jit": {"const": true},
        "prove_ms_is_diagnostic_only": {"const": true},
        "no_concurrent_benchmarks": {"const": true}
      }
    },
    "executables": {
      "type": "object",
      "required": ["peer_cpu", "peer_metal", "zig_cpu", "zig_metal"],
      "properties": {
        "peer_cpu": {"$ref": "#/$defs/executable"},
        "peer_metal": {"$ref": "#/$defs/executable"},
        "zig_cpu": {"$ref": "#/$defs/executable"},
        "zig_metal": {"$ref": "#/$defs/executable"}
      }
    },
    "coverage": {
      "type": "object",
      "required": ["wide_fibonacci_complete", "full_pr6_matrix_complete", "missing_exact_workloads"],
      "properties": {
        "wide_fibonacci_complete": {"const": true},
        "full_pr6_matrix_complete": {"const": false},
        "missing_exact_workloads": {"type": "array", "minItems": 4, "items": {"type": "string"}}
      }
    },
    "sizes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {"allOf": [{"$ref": "#/$defs/size"}, {"properties": {"log_n_rows": {"const": 14}}}]},
        {"allOf": [{"$ref": "#/$defs/size"}, {"properties": {"log_n_rows": {"const": 16}}}]},
        {"allOf": [{"$ref": "#/$defs/size"}, {"properties": {"log_n_rows": {"const": 18}}}]},
        {"allOf": [{"$ref": "#/$defs/size"}, {"properties": {"log_n_rows": {"const": 20}}}]},
        {"allOf": [{"$ref": "#/$defs/size"}, {"properties": {"log_n_rows": {"const": 22}}}]}
      ]
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "executable": {
      "type": "object",
      "required": ["path", "sha256", "build_command"],
      "properties": {
        "path": {"type": "string"},
        "sha256": {"$ref": "#/$defs/sha256"},
        "build_command": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "size": {
      "type": "object",
      "required": [
        "cell_id",
        "log_n_rows",
        "rows",
        "n_columns",
        "resource_profile",
        "committed_cells",
        "accounted_bytes",
        "descriptor",
        "comparisons",
        "proof_equivalence"
      ],
      "properties": {
        "cell_id": {"type": "string"},
        "log_n_rows": {"enum": [14, 16, 18, 20, 22]},
        "rows": {"type": "integer", "minimum": 16384},
        "n_columns": {"const": 100},
        "resource_profile": {"enum": ["standard", "large", "extreme"]},
        "committed_cells": {"type": "integer"},
        "accounted_bytes": {"type": "integer"},
        "descriptor": {"type": "object"},
        "comparisons": {
          "type": "object",
          "required": ["cpu", "metal"],
          "properties": {
            "cpu": {"$ref": "#/$defs/comparison"},
            "metal": {"$ref": "#/$defs/comparison"}
          }
        },
        "proof_equivalence": {"type": "object"}
      }
    },
    "comparison": {
      "type": "object",
      "required": ["verified_request", "cold_process"],
      "properties": {
        "verified_request": {"$ref": "#/$defs/boundary"},
        "cold_process": {"$ref": "#/$defs/boundary"}
      }
    },
    "boundary": {
      "type": "object",
      "required": ["boundary", "warmups_before_each_timed_sample", "rounds", "statistics"],
      "properties": {
        "boundary": {"enum": ["verified_request", "cold_process"]},
        "warmups_before_each_timed_sample": {"enum": [0, 10]},
        "rounds": {"type": "array", "minItems": 7, "items": {"$ref": "#/$defs/round"}},
        "statistics": {"type": "object"}
      }
    },
    "round": {
      "type": "object",
      "required": ["round", "order", "samples"],
      "properties": {
        "round": {"type": "integer", "minimum": 0},
        "order": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"type": "string"}},
        "samples": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/sample"}}
      }
    },
    "sample": {
      "type": "object",
      "required": [
        "lane",
        "reported_prove_ms",
        "verified_request_ms",
        "invocation_wall_ms",
        "trace_row_mhz",
        "committed_cell_mhz",
        "proof_identity",
        "verified",
        "protocol",
        "protocol_sha256",
        "statement_sha256",
        "resource_admission",
        "process_resources",
        "metal_dispatches",
        "metal_synchronization_points",
        "metal_cpu_fallbacks",
        "round",
        "abba_position",
        "abba_half",
        "boundary",
        "warmups_before_sample"
      ],
      "properties": {
        "lane": {"enum": ["peer_cpu", "peer_metal", "zig_cpu", "zig_metal"]},
        "reported_prove_ms": {"type": "number", "exclusiveMinimum": 0},
        "verified_request_ms": {"type": "number", "exclusiveMinimum": 0},
        "invocation_wall_ms": {"type": "number", "exclusiveMinimum": 0},
        "cold_process_ms": {"type": "number", "exclusiveMinimum": 0},
        "trace_row_mhz": {"type": "number", "exclusiveMinimum": 0},
        "committed_cell_mhz": {"type": "number", "exclusiveMinimum": 0},
        "proof_identity": {"type": "object"},
        "verified": {"const": true},
        "protocol": {"type": "object"},
        "protocol_sha256": {"$ref": "#/$defs/sha256"},
        "statement_sha256": {"$ref": "#/$defs/sha256"},
        "resource_admission": {"type": "object"},
        "process_resources": {"type": "object"},
        "reported_resources": {"type": ["object", "null"]},
        "metal_runtime": {"type": ["object", "null"]},
        "metal_device_admitted": {"type": "boolean"},
        "trace_generation_backend": {"type": "string"},
        "metal_dispatches": {"type": ["integer", "null"]},
        "metal_synchronization_points": {"type": ["integer", "null"]},
        "metal_cpu_fallbacks": {"type": ["integer", "null"]},
        "raw_report_sha256": {"$ref": "#/$defs/sha256"},
        "round": {"type": "integer", "minimum": 0},
        "abba_position": {"type": "integer", "minimum": 0, "maximum": 3},
        "abba_half": {"enum": [1, 2]},
        "boundary": {"enum": ["verified_request", "cold_process"]},
        "warmups_before_sample": {"enum": [0, 10]}
      }
    }
  }
}
