{
  "authority": {
    "candidate_must_differ": true,
    "commit_source": "protected-repository-variable:ARCHITECTURE_AUTHORITY_SHA",
    "plan_path": "conformance/build-architecture-ci-plan-v1.json",
    "repository": "teddyjfpender/stwo-zig"
  },
  "authority_state_path": "conformance/build-architecture-authority-state-v1.json",
  "authority_workflow": {
    "aggregate_job": "architecture-authority-verify",
    "host_jobs": {
      "linux": "architecture-authority-linux",
      "macos": "architecture-authority-macos"
    },
    "path": ".github/workflows/architecture-authority.yml",
    "ref": "teddyjfpender/stwo-zig/.github/workflows/architecture-authority.yml@refs/heads/main"
  },
  "candidate_workflow": {
    "path": ".github/workflows/ci.yml",
    "role": "diagnostic-only"
  },
  "execution": {
    "candidate_checkout": "exact-clean-commit",
    "host_tools": "role-matching",
    "plan_and_python_policy": "authenticated-authority-checkout",
    "preimages": "audit-only-not-execution-authority",
    "zig_sources_and_binaries": "exact-candidate-checkout"
  },
  "final_receipt_issuer": "protected-authority-workflow-or-external-server",
  "protected_environment": "build-architecture-authority",
  "required_check_context": "Build architecture authority / verify",
  "schema": "build-architecture-external-verifier-v1"
}
