{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stwo-zig.dev/schemas/source-baseline.schema.json",
  "title": "Stwo Zig source-conformance baseline",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "findings"
  ],
  "properties": {
    "version": {
      "const": 3
    },
    "findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/finding"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "owner",
        "reason",
        "next_extraction",
        "plan"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "next_extraction": {
          "type": "string",
          "minLength": 1
        },
        "plan": {
          "type": "string",
          "minLength": 1
        },
        "max_lines": {
          "type": "integer",
          "exclusiveMinimum": 850
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "key": {
                "pattern": "^file-size:"
              }
            },
            "required": [
              "key"
            ]
          },
          "then": {
            "required": [
              "max_lines"
            ]
          },
          "else": {
            "not": {
              "required": [
                "max_lines"
              ]
            }
          }
        }
      ]
    }
  }
}
